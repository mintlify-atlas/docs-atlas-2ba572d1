  "keyFeatures": [
    "Privacy-first architecture with guest mode and local storage",
    "Real-time preview with multiple professional templates",
    "Version control system with auto-save and conflict resolution",
    "ATS-friendly PDF export with professional formatting",
    "Firebase authentication and cloud synchronization",
    "Intelligent three-way merge for conflict resolution",
    "Profile image upload with crop and storage",
    "Flexible section management with drag-and-drop reordering"
  ],
  "publicApiSurface": [
    "CVBuilder - Main resume builder component",
    "saveCV() - Save CV data to cloud",
    "loadCV() - Load CV data from cloud",
    "saveVersion() - Create named version",
    "restoreVersion() - Restore previous version",
    "deleteVersion() - Remove version",
    "generatePDF() - Export resume as PDF",
    "useCVDraft() - Auto-save draft hook",
    "useCVVersions() - Version management hook",
    "useResumeList() - Resume listing hook",
    "CVData - Main data structure type",
    "TemplateId - Template selection type",
    "CVVersion - Version control type"
  ]
